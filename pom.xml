<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>dev.apronterm</groupId>
    <artifactId>apronterm</artifactId>
    <version>0.1.0</version>
    <packaging>jar</packaging>

    <name>apronTERM</name>
    <description>A Swing terminal that organises Windows Terminal profiles into switchable projects.</description>

    <properties>
        <maven.compiler.release>21</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <!-- Build number for the auto-updater: a timestamp that changes every release, so the native
             launcher sees a new version. Drives <pkgrel> in update.xml and the version entry in
             version.xml; also reused (informationally) for <pubDate>. -->
        <maven.build.timestamp.format>yyyyMMddHHmm</maven.build.timestamp.format>
        <jediterm.version>3.72</jediterm.version>
        <pty4j.version>0.13.12</pty4j.version>
        <jackson.version>2.22.0</jackson.version>
        <flatlaf.version>3.7.1</flatlaf.version>
        <slf4j.version>2.0.9</slf4j.version>
        <annotations.version>24.0.1</annotations.version>
        <main.class>dev.apronterm.ApronTerm</main.class>
    </properties>

    <repositories>
        <!-- JediTerm is not on Maven Central; it lives in the JetBrains intellij-dependencies repo. -->
        <repository>
            <id>intellij-dependencies</id>
            <url>https://cache-redirector.jetbrains.com/intellij-dependencies</url>
            <releases><enabled>true</enabled></releases>
            <snapshots><enabled>false</enabled></snapshots>
        </repository>
    </repositories>

    <dependencies>
        <!-- Terminal emulator (Swing widget) + its core. -->
        <dependency>
            <groupId>org.jetbrains.jediterm</groupId>
            <artifactId>jediterm-ui</artifactId>
            <version>${jediterm.version}</version>
        </dependency>
        <dependency>
            <groupId>org.jetbrains.jediterm</groupId>
            <artifactId>jediterm-core</artifactId>
            <version>${jediterm.version}</version>
        </dependency>

        <!-- Pseudo-console (ConPTY on Windows) so shells run interactively. -->
        <dependency>
            <groupId>org.jetbrains.pty4j</groupId>
            <artifactId>pty4j</artifactId>
            <version>${pty4j.version}</version>
        </dependency>

        <!-- JSON for Windows Terminal settings.json + our own config files. -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>${jackson.version}</version>
        </dependency>

        <!-- Modern flat dark/light look and feel for the Swing chrome. -->
        <dependency>
            <groupId>com.formdev</groupId>
            <artifactId>flatlaf</artifactId>
            <version>${flatlaf.version}</version>
        </dependency>

        <!-- @NotNull/@Nullable used by the vendored Pty connector. -->
        <dependency>
            <groupId>org.jetbrains</groupId>
            <artifactId>annotations</artifactId>
            <version>${annotations.version}</version>
        </dependency>

        <!-- A concrete SLF4J binding so JediTerm/pty4j log to the console instead of warning. -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-simple</artifactId>
            <version>${slf4j.version}</version>
            <scope>runtime</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>apronterm-${project.version}</finalName>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
            </plugin>

            <!-- Build a single runnable fat-jar: java -jar target/quay-0.1.0.jar -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals><goal>shade</goal></goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>${main.class}</mainClass>
                                </transformer>
                                <!-- Merge service files (pty4j/jackson rely on them). -->
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                        <exclude>module-info.class</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Release artifacts for the auto-updater (`mvn verify`), all written under target/:
                   * version.xml  — local version marker, shipped INSIDE apronterm.zip and extracted
                                    next to the jar (updater reads /properties/entry[@key='version']).
                   * update.xml   — remote version file published loose as a release asset
                                    (updater reads /information/pkgrel).
                   * java/        — a bundled JRE (jlink) so the launcher carries no JRE of its own;
                                    the launcher puts <unzip>/java/bin on PATH and starts the JVM.
                   * apronterm.zip — the fat-jar + version.xml + the java/ JRE, what the updater unzips.
                 NB: jlink produces a runtime for the OS it runs on, so the release CI must run on
                 Windows. The CI workflow uploads update.xml + apronterm.zip as GitHub release assets. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>3.1.0</version>
                <executions>
                    <execution>
                        <phase>verify</phase>
                        <id>build-update-artifacts</id>
                        <configuration>
                            <target>
                                <copy overwrite="true" file="version.xml.tmpl"
                                      tofile="${project.build.directory}/version.xml"/>
                                <copy overwrite="true" file="update.xml.tmpl"
                                      tofile="${project.build.directory}/update.xml"/>
                                <replace dir="${project.build.directory}" includes="version.xml,update.xml"
                                         token="$BUILD_NUMBER$" value="${maven.build.timestamp}"/>
                                <replace file="${project.build.directory}/update.xml"
                                         token="$BUILD_DATE$" value="${maven.build.timestamp}"/>

                                <!-- Bundle a self-contained JRE under java/ (jlink needs a fresh dir). -->
                                <delete dir="${project.build.directory}/java"/>
                                <exec executable="${java.home}/bin/jlink" failonerror="true">
                                    <arg value="--add-modules"/>
                                    <arg value="java.se"/>
                                    <arg value="--strip-debug"/>
                                    <arg value="--no-header-files"/>
                                    <arg value="--no-man-pages"/>
                                    <arg value="--output"/>
                                    <arg value="${project.build.directory}/java"/>
                                </exec>

                                <!-- Jar goes in under a stable, version-free name so the launcher's
                                     JAR config never changes between releases (it ships once and
                                     self-updates); the version is tracked only via version.xml. -->
                                <zip destfile="${project.build.directory}/apronterm.zip">
                                    <zipfileset file="${project.build.directory}/apronterm-${project.version}.jar"
                                                fullpath="apronterm.jar"/>
                                    <fileset dir="${project.build.directory}" includes="version.xml"/>
                                    <zipfileset dir="${project.build.directory}/java" prefix="java"/>
                                </zip>
                            </target>
                        </configuration>
                        <goals><goal>run</goal></goals>
                    </execution>
                </executions>
            </plugin>

            <!-- Convenience: mvn exec:java to run from sources. -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.5.0</version>
                <configuration>
                    <mainClass>${main.class}</mainClass>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
